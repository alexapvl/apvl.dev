---
import { getCollection, type CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import "../../styles/prose.css";

export async function getStaticPaths() {
  const projects = await getCollection("stuff");
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: project,
  }));
}

type Props = CollectionEntry<"stuff">;

const project = Astro.props;
const { Content } = await project.render();
---

<BaseLayout
  title={`${project.data.title} | apvl.dev`}
  description={project.data.description}
  image={project.data.cover?.src}
>
  <article class="page">
    <header class="page-header">
      <div class="project-meta">
        <span class="project-year">{project.data.pubDate.getFullYear()}</span>
      </div>
      <h1 class="page-title project-title">{project.data.title}</h1>
      <p class="page-description project-description">
        {project.data.description}
      </p>

      <div class="project-tech">
        {project.data.tech.map((t) => <span class="tech-pill">{t}</span>)}
      </div>

      <div class="project-links">
        {
          project.data.github && (
            <a
              href={project.data.github}
              target="_blank"
              rel="noopener noreferrer"
              class="project-link"
            >
              <svg
                viewBox="0 0 24 24"
                width="18"
                height="18"
                fill="currentColor"
              >
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
              </svg>
              source
            </a>
          )
        }
        {
          project.data.demo && (
            <a
              href={project.data.demo}
              target="_blank"
              rel="noopener noreferrer"
              class="project-link"
            >
              <svg
                viewBox="0 0 24 24"
                width="18"
                height="18"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
              >
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                <polyline points="15 3 21 3 21 9" />
                <line x1="10" y1="14" x2="21" y2="3" />
              </svg>
              demo
            </a>
          )
        }
      </div>
    </header>

    {
      project.data.cover && (
        <img src={project.data.cover.src} alt="" class="cover-image" />
      )
    }

    <div class="prose">
      <Content />
    </div>

    <footer class="project-footer">
      <p class="back-link-text">
        back to <a href="/stuff" class="back-link">/stuff</a>
      </p>
    </footer>
  </article>
</BaseLayout>

<style>
  .project-meta {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-top: calc(-1 * var(--space-xl));
    margin-bottom: var(--space-sm);
  }

  .project-year {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
  }

  .project-title {
    margin-bottom: var(--space-md);
  }

  .project-description {
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-lg);
  }

  .project-tech {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-bottom: var(--space-lg);
  }

  .tech-pill {
    font-size: var(--font-size-sm);
    color: var(--color-accent);
    background-color: color-mix(in srgb, var(--color-accent) 10%, transparent);
    padding: var(--space-xs) var(--space-md);
    border-radius: var(--radius-full);
  }

  .project-links {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .project-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--font-size-sm);
    color: var(--color-text);
    text-decoration: none;
    padding: var(--space-sm) var(--space-md);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    transition: all var(--transition-fast);
  }

  .project-link:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .cover-image {
    width: 100%;
    border-radius: var(--radius-lg);
    margin-bottom: var(--space-2xl);
    border: 1px solid var(--color-border);
  }

  .project-footer {
    margin-top: var(--space-3xl);
    padding-top: var(--space-xl);
    border-top: 1px solid var(--color-border);
  }

  .back-link-text {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-sm);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .back-link:hover {
    color: var(--color-accent);
  }
</style>
