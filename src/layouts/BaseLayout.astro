---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import NoiseBackground from "../components/NoiseBackground.astro";
import NavPanel from "../components/NavPanel.astro";
import MobileNav from "../components/MobileNav.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description, image } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} image={image} />
  </head>
  <body>
    <NoiseBackground />
    <main class="main">
      <slot />
    </main>
    <Footer />
    <NavPanel />
    <MobileNav />
  </body>
</html>

<script>
  import { initTheme } from "../scripts/theme";
  import { initKeybinds } from "../scripts/keybinds";

  // Check if device is mobile/touch-only
  function isMobileDevice(): boolean {
    return window.matchMedia("(max-width: 640px)").matches;
  }

  // Make external links in prose open in new tab
  function setupExternalLinks() {
    const proseLinks = document.querySelectorAll(".prose a");
    proseLinks.forEach((link) => {
      const href = link.getAttribute("href");
      if (
        href?.startsWith("http") &&
        !href.includes(window.location.hostname)
      ) {
        link.setAttribute("target", "_blank");
        link.setAttribute("rel", "noopener noreferrer");
      }
    });
  }

  function setup() {
    initTheme();

    // Only load keybinds on desktop - mobile uses touch navigation
    if (!isMobileDevice()) {
      initKeybinds();
    }

    setupExternalLinks();
  }

  // Run on initial load
  setup();

  // Run on View Transitions navigation
  document.addEventListener("astro:page-load", setup);
</script>
