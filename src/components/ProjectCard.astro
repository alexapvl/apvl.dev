---
import type { ProjectRepoMeta } from "../data/project-meta";
import type { ProjectRole } from "../utils/project-status";
import { getProjectStatusContext } from "../utils/project-status";
import ProjectStatus from "./ProjectStatus.astro";

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tech: string[];
  github?: string;
  slug: string;
  role: ProjectRole;
  lastTouched?: Date;
  repoMeta?: ProjectRepoMeta;
}

const {
  title,
  description,
  pubDate,
  tech,
  slug,
  role,
  lastTouched,
  github,
  repoMeta,
} = Astro.props;
const year = pubDate.getFullYear();
const { activityLabel, relativeAt } = getProjectStatusContext({
  lastTouched,
  github,
  repoMeta,
});
---

<article class="project-card">
  <a href={`/stuff/${slug}`} class="card-link">
    <div class="card-header">
      <div class="card-title-block">
        <h3 class="card-title">
          <span class="card-title-text">{title}</span>
          <span class="card-title-sep" aria-hidden="true">·</span>
          <span class="card-role">{role}</span>
        </h3>
      </div>
      {
        activityLabel && (
          relativeAt ? (
            <span
              class="card-updated"
              data-relative-at={relativeAt}
              data-relative-prefix="updated"
            >
              {activityLabel}
            </span>
          ) : (
            <span class="card-updated">{activityLabel}</span>
          )
        )
      }
    </div>
  </a>

  <a href={`/stuff/${slug}`} class="card-link card-link-body">
    <p class="card-description">{description}</p>

    <div class="card-footer">
      <div class="card-tech">
        {tech.map((t) => <span class="tech-pill">{t}</span>)}
      </div>
      <span class="card-year">{year}</span>
    </div>
  </a>

  <ProjectStatus
    role={role}
    lastTouched={lastTouched}
    github={github}
    repoMeta={repoMeta}
    variant="card"
    showMeta={false}
    showActivity={false}
  />

  <style>
    .project-card {
      display: flex;
      flex-direction: column;
      background-color: color-mix(
        in srgb,
        var(--color-bg-secondary) 50%,
        transparent
      );
      border: 1px solid var(--color-border);
      border-radius: var(--radius-lg);
      overflow: hidden;
      transition:
        border-color var(--transition-fast),
        box-shadow var(--transition-fast);
    }

    .project-card:hover {
      border-color: var(--color-accent);
      box-shadow: var(--shadow-md);
    }

    .card-link {
      display: block;
      padding: var(--space-lg) var(--space-lg) 0;
      text-decoration: none;
      color: inherit;
    }

    .card-link-body {
      padding-top: var(--space-sm);
      padding-bottom: var(--space-lg);
    }

    .project-card:has(.project-status) .card-link-body {
      padding-bottom: var(--space-md);
    }

    .card-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: var(--space-md);
      margin-bottom: var(--space-xs);
    }

    .card-title-block {
      min-width: 0;
    }

    .card-title {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.35em;
      font-size: var(--font-size-lg);
      line-height: var(--leading-tight);
      min-width: 0;
    }

    .card-title-text {
      font-weight: 600;
      color: var(--color-text);
    }

    .card-title-sep {
      font-weight: 400;
      color: var(--color-text-muted);
      opacity: 0.55;
    }

    .card-role {
      font-size: inherit;
      font-weight: 400;
      color: var(--color-text-secondary);
    }

    .card-updated {
      flex-shrink: 0;
      font-size: var(--font-size-xs);
      color: var(--color-text-muted);
      padding-top: 0.25em;
      text-align: right;
      white-space: nowrap;
    }

    .card-description {
      font-size: var(--font-size-sm);
      color: var(--color-text-secondary);
      line-height: var(--leading-relaxed);
      margin-bottom: var(--space-md);
    }

    .card-footer {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      gap: var(--space-md);
    }

    .card-tech {
      display: flex;
      flex-wrap: wrap;
      gap: var(--space-xs);
      min-width: 0;
    }

    .card-year {
      flex-shrink: 0;
      font-size: var(--font-size-sm);
      color: var(--color-text-muted);
      line-height: 1;
    }

    .tech-pill {
      font-size: var(--font-size-xs);
      color: var(--color-accent);
      background-color: color-mix(
        in srgb,
        var(--color-accent) 10%,
        transparent
      );
      padding: 2px var(--space-sm);
      border-radius: var(--radius-full);
    }
  </style>
</article>
