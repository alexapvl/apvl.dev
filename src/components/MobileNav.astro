---
// Mobile navigation component with hamburger menu and bottom sheet
// Only visible on mobile (< 640px)
---

<div id="mobile-nav" transition:persist="mobile-nav">
  <!-- Sheet content container (drwr wraps this at runtime) -->
  <div id="mobile-sheet" hidden>
  <nav class="sheet-nav">
    <a href="/" class="nav-link">home</a>
    <a href="/thoughts" class="nav-link">thoughts</a>
    <a href="/stuff" class="nav-link">stuff</a>
  </nav>

  <div class="sheet-actions">
    <button
      class="action-btn off"
      id="mobile-music-toggle"
      aria-label="Toggle music"
    >
      <span class="action-text" id="mobile-music-text">music</span>
    </button>
    <button
      class="action-btn"
      id="mobile-theme-toggle"
      aria-label="Toggle theme"
    >
      <span class="action-text" id="mobile-theme-text">dark</span>
    </button>
  </div>
</div>

<!-- Hamburger button -->
<button
  class="hamburger-btn"
  id="hamburger-btn"
  aria-label="Open menu"
  aria-expanded="false"
>
  <div class="hamburger-lines">
    <span class="line line-top"></span>
    <span class="line line-middle"></span>
    <span class="line line-bottom"></span>
  </div>
</button>
</div>

<style>
  #mobile-nav,
  #mobile-sheet,
  .hamburger-btn {
    display: none;
  }

  @media (max-width: 640px) {
    #mobile-nav {
      display: contents;
    }

    #mobile-sheet:not([hidden]) {
      display: block;
    }

    /* Navigation */
    .sheet-nav {
      display: flex;
      flex-direction: column;
      gap: var(--space-xs);
    }

    .nav-link {
      display: block;
      padding: var(--space-md) var(--space-sm);
      font-size: var(--font-size-lg);
      color: var(--color-text);
      text-decoration: none;
      border-radius: var(--radius-md);
      transition:
        background-color var(--transition-fast),
        color var(--transition-fast);
    }

    .nav-link:hover,
    .nav-link:focus {
      background-color: var(--color-bg-secondary);
      color: var(--color-accent);
    }

    /* Actions section */
    .sheet-actions {
      display: flex;
      gap: var(--space-md);
      margin-top: var(--space-lg);
      padding-top: var(--space-md);
      border-top: 1px solid var(--color-border-subtle);
    }

    .action-btn {
      flex: 1;
      padding: var(--space-md) var(--space-sm);
      font-family: inherit;
      font-size: var(--font-size-lg);
      color: var(--color-text);
      background: none;
      border: none;
      border-radius: var(--radius-md);
      cursor: pointer;
      outline: none;
      -webkit-tap-highlight-color: transparent;
      transition: background-color var(--transition-fast);
    }

    .action-btn:hover {
      background-color: var(--color-bg-secondary);
    }

    .action-text {
      position: relative;
      display: inline-block;
    }

    /* Strikethrough animation */
    .action-text::after {
      content: "";
      position: absolute;
      left: 0;
      top: 50%;
      width: 100%;
      height: 2px;
      background-color: var(--color-text);
      transform: scaleX(0);
      transform-origin: left;
      transition: transform 200ms ease;
    }

    .action-btn.off .action-text::after {
      transform: scaleX(1);
    }

    .action-btn.off .action-text {
      color: var(--color-text-muted);
    }

    /* Hamburger button */
    .hamburger-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      position: fixed;
      top: var(--space-lg);
      right: var(--space-lg);
      width: 48px;
      height: 48px;
      z-index: var(--z-mobile-nav);
      background: linear-gradient(
        135deg,
        color-mix(in srgb, var(--color-bg) 95%, transparent),
        color-mix(in srgb, var(--color-bg) 80%, transparent)
      );
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid var(--color-border);
      border-radius: 50%;
      box-shadow: var(--shadow-lg);
      cursor: pointer;
      transition:
        transform var(--transition-fast),
        box-shadow var(--transition-fast);
    }

    .hamburger-btn:hover {
      transform: scale(1.05);
      box-shadow:
        var(--shadow-lg),
        0 0 0 3px var(--color-border-subtle);
    }

    .hamburger-btn:active {
      transform: scale(0.95);
    }

    /* Hamburger lines */
    .hamburger-lines {
      position: relative;
      width: 20px;
      height: 14px;
    }

    .line {
      position: absolute;
      left: 0;
      width: 100%;
      height: 2px;
      background-color: var(--color-text);
      border-radius: var(--radius-full);
      transform-origin: center;
      transition:
        transform 300ms ease-out,
        opacity 200ms ease-in-out;
    }

    .line-top {
      top: 0;
      transition-delay: 0s;
    }

    .line-middle {
      top: 50%;
      transform: translateY(-50%);
      transition-delay: 0.1s;
    }

    .line-bottom {
      bottom: 0;
      transition-delay: 0s;
    }

    /* Hamburger open state (X) */
    .hamburger-btn[aria-expanded="true"] .line-top {
      transform: translateY(6px) rotate(45deg);
      transition-delay: 0.1s;
    }

    .hamburger-btn[aria-expanded="true"] .line-middle {
      opacity: 0;
      transform: translateY(-50%) scale(0);
      transition-delay: 0s;
    }

    .hamburger-btn[aria-expanded="true"] .line-bottom {
      transform: translateY(-6px) rotate(-45deg);
      transition-delay: 0.1s;
    }
  }
</style>

<script>
  import {
    initMobileNav,
    syncMobileNavState,
  } from "../scripts/mobile-nav";
  import * as musicPlayer from "../scripts/music-player";

  let musicClickHandler: (() => void) | null = null;
  let themeClickHandler: (() => void) | null = null;

  function initMusicToggle() {
    const btnEl = document.getElementById("mobile-music-toggle");

    if (!btnEl) return;

    const btn = btnEl;

    function updateUI() {
      const isPlaying = musicPlayer.isPlaying();
      btn.classList.toggle("off", !isPlaying);
    }

    updateUI();

    if (musicClickHandler) {
      btn.removeEventListener("click", musicClickHandler);
    }

    musicClickHandler = async () => {
      await musicPlayer.toggle();
      updateUI();
    };

    btn.addEventListener("click", musicClickHandler);

    (window as any).musicPlayer = musicPlayer;
  }

  function initThemeToggle() {
    const btnEl = document.getElementById("mobile-theme-toggle");
    const textEl = document.getElementById("mobile-theme-text");

    if (!btnEl || !textEl) return;

    const btn = btnEl;
    const text = textEl;

    function getCurrentTheme(): "light" | "dark" {
      return (
        (document.documentElement.getAttribute("data-theme") as
          | "light"
          | "dark") || "dark"
      );
    }

    function updateUI() {
      const theme = getCurrentTheme();
      text.textContent = theme;
    }

    updateUI();

    if (themeClickHandler) {
      btn.removeEventListener("click", themeClickHandler);
    }

    themeClickHandler = () => {
      if (typeof (window as any).toggleTheme === "function") {
        (window as any).toggleTheme();
        updateUI();
      }
    };

    btn.addEventListener("click", themeClickHandler);

    window.addEventListener("themechange", updateUI);
  }

  function setup() {
    initMobileNav();
    initMusicToggle();
    initThemeToggle();
  }

  setup();

  document.addEventListener("astro:after-swap", syncMobileNavState);
  document.addEventListener("astro:page-load", setup);
</script>
